default_platform(:ios)

WORKSPACE = "ios/BroadcastBrain.xcworkspace"
SCHEME = "BroadcastBrain"
BUNDLE_ID = "com.nicolasdossantos.broadcastbrain"

platform :ios do
  before_all do
    ensure_env_vars(
      env_vars: %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_PATH]
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )

    cocoapods(podfile: "ios/Podfile", try_repo_update_on_error: true)

    latest = latest_testflight_build_number(
      app_identifier: BUNDLE_ID,
      api_key: api_key
    )
    increment_build_number(
      xcodeproj: "ios/BroadcastBrain.xcodeproj",
      build_number: latest + 1
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "BroadcastBrain.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      ipa: "build/BroadcastBrain.ipa"
    )
  end

  desc "Build IPA only (no upload)"
  lane :build do
    cocoapods(podfile: "ios/Podfile", try_repo_update_on_error: true)
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "BroadcastBrain.ipa"
    )
  end
end
